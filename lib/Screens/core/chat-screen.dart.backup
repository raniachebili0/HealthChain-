                          mainAxisAlignment: MainAxisAlignment.center,
                          children: [
                            Icon(
                              _messages.last.read ? Icons.done_all : Icons.done,
                              size: 14, 
                              color: _messages.last.read ? Colors.teal : Colors.grey,
                            ),
                            SizedBox(width: 4),
                            Text(
                              _messages.last.read ? "Read" : "Delivered",
                              style: TextStyle(
                                color: _messages.last.read ? Colors.teal : Colors.grey,
                                fontSize: 12,
                              ),
                            ),
                          ],
                        ),
                      ),
                    // Input field and buttons
                    Row(
                      children: [
                        IconButton(
                          icon: Icon(Icons.attach_file, color: Colors.grey),
                          onPressed: () {},
                        ),
                        Expanded(
                          child: Container(
                            padding: EdgeInsets.symmetric(horizontal: 16),
                            height: 40,
                            decoration: BoxDecoration(
                              color: Colors.grey.shade100,
                              borderRadius: BorderRadius.circular(20),
                            ),
                            child: TextField(
                              controller: _controller,
                              decoration: InputDecoration(
                                hintText: 'Type message...',
                                border: InputBorder.none,
                                hintStyle: TextStyle(color: Colors.grey),
                              ),
                              onChanged: (text) {
                                // Notify typing status
                                _setTyping(text.isNotEmpty);
                              },
                            ),
                          ),
                        ),
                        SizedBox(width: 8),
                        Container(
                          height: 40,
                          width: 80,
                          decoration: BoxDecoration(
                            color: Colors.teal,
                            borderRadius: BorderRadius.circular(20),
                          ),
                          child: TextButton(
                            onPressed: () => sendMessage(_controller.text),
                            child: Text(
                              'Send',
                              style: TextStyle(color: Colors.white),
                            ),
                          ),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ],
          ),
          
          // Notification banner for new messages
          if (_showNotificationBanner && _notificationMessage != null)
            Positioned(
              top: 0,
              left: 0,
              right: 0,
              child: GestureDetector(
                onTap: () {
                  // Scroll to the new message when banner is tapped
                  _scrollToBottom();
                  setState(() {
                    _showNotificationBanner = false;
                    _notificationMessage = null;
                  });
                },
                child: Container(
                  margin: EdgeInsets.all(8),
                  padding: EdgeInsets.symmetric(horizontal: 16, vertical: 10),
                  decoration: BoxDecoration(
                    color: Colors.green.shade100,
                    borderRadius: BorderRadius.circular(12),
                  ),
                  child: Row(
                    children: [
                      CircleAvatar(
                        backgroundImage: AssetImage(_getOtherParticipantAvatar()),
                        radius: 16,
                      ),
                      SizedBox(width: 12),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          mainAxisSize: MainAxisSize.min,
                          children: [
                            Text(
                              _getOtherParticipantName(),
                              style: TextStyle(
                                fontWeight: FontWeight.bold,
                                fontSize: 14,
                              ),
                            ),
                            Text(
                              _notificationMessage!.content,
                              style: TextStyle(fontSize: 13),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                            ),
                          ],
                        ),
                      ),
                      Icon(Icons.arrow_downward, color: Colors.green.shade700),
                    ],
                  ),
                ),
              ),
            ),
        ],
      ),
    );
  }

  // Add this method to add a call button to the app bar
  List<Widget> _buildAppBarActions() {
    return [
      // Add the call button
      IconButton(
        icon: Icon(Icons.phone, color: Colors.white),
        onPressed: () {
          print('[CHAT] Call button clicked');
          _initiateAudioCall();
        },
      ),
    ];
  }

  // Add this method to initiate an audio call
  void _initiateAudioCall() {
    print('[CALL] Initiating audio call...');
    
    if (socket == null || !socket!.connected) {
      print('[CALL] Socket not connected, cannot initiate call');
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Cannot start call: not connected to server'))
      );
      return;
    }
    
    if (_currentUserId == null || _conversation == null) {
      print('[CALL] Missing user ID or conversation, trying to get receiver ID from conversation data');
      
      // Try to get receiver ID from conversation participants
      String? receiverId;
      if (_conversation != null) {
        for (final participant in _conversation!.participants) {
          // Handle participant that can be string or object
          String participantId = '';
          if (participant is String) {
            participantId = participant;
          } else if (participant is Map<String, dynamic> && participant.containsKey('_id')) {
            participantId = participant['_id'] as String;
          }
          
          if (participantId.isNotEmpty && participantId != _currentUserId) {
            receiverId = participantId;
            break;
          }
        }
      }
      
      if (receiverId == null) {
        print('[CALL] Could not determine receiver ID');
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Cannot start call: missing receiver information'))
        );
        return;
      }
      
      _emitCallInitiation(receiverId);
    } else {
      // Find the receiver ID (the other participant in the conversation)
      String? receiverId;
      for (final participant in _conversation!.participants) {
        // Handle participant that can be string or object
        String participantId = '';
        if (participant is String) {
          participantId = participant;
        } else if (participant is Map<String, dynamic> && participant.containsKey('_id')) {
          participantId = participant['_id'] as String;
        }
        
        if (participantId.isNotEmpty && participantId != _currentUserId) {
          receiverId = participantId;
          break;
        }
      }
      
      if (receiverId == null) {
        print('[CALL] Could not determine receiver ID');
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Cannot start call: missing receiver information'))
        );
        return;
      }
      
      _emitCallInitiation(receiverId);
    }
  }

  void _emitCallInitiation(String receiverId) {
    print('[CALL] Emitting initiate_call event to receiver: $receiverId');
    print('[CALL] Conversation ID: ${_conversation?.id}');
    
    // Register for call-related events if not already done
    _setupCallEventListeners();
    
    // Get the sender name and avatar to pass with the call
    String senderName = "User";
    String senderAvatar = "assets/images/avatar.png";
    
    // Try to get sender info from storage
    _getSenderInfo().then((info) {
      if (info != null) {
        senderName = info['name'] ?? senderName;
        senderAvatar = info['avatar'] ?? senderAvatar;
      }
      
      // Show calling dialog/screen to provide immediate feedback
      _showCallingDialog(receiverId);
      
      // Generate a unique call ID that includes both users
      final callId = 'call_${_currentUserId}_${receiverId}_${DateTime.now().millisecondsSinceEpoch}';
      
      // Send complete call information
      final callData = {
        'callerId': _currentUserId,
        'callerName': senderName,
        'callerAvatar': senderAvatar,
        'receiverId': receiverId,
        'conversationId': _conversation?.id ?? '',
        'timestamp': DateTime.now().toIso8601String(),
        'callId': callId
      };
      
      // Emit multiple variants of the call event for compatibility
      // with different server implementations
      
      // Specific targeted call to the receiver's room
      socket!.emit('direct_call', {
        'targetRoom': receiverId,
        'data': callData
      });
      
      // Standard initiate_call event
      socket!.emit('initiate_call', callData);
      
      // Generic call_user event used by many socket implementations
      socket!.emit('call_user', callData);
      
      // Debug event that broadcasts to everyone - useful for testing
      socket!.emit('debug_call', {
        'message': 'Call initiated from $_currentUserId to $receiverId',
        'callData': callData
      });
      
      print('[CALL] Sent call initiation with data: $callData');
      
      // Request server to acknowledge the call initiation
      socket!.emitWithAck('verify_call_sent', callData, ack: (data) {
        print('[CALL] Server acknowledged call initiation: $data');
      });
    });
  }

  // Helper method to get sender info
  Future<Map<String, String>?> _getSenderInfo() async {
    try {
      final userJson = await storage.read(key: 'user');
      if (userJson != null) {
        final userData = json.decode(userJson);
        return {
          'name': userData['name'] ?? 'User',
          'avatar': userData['avatar'] ?? 'assets/images/avatar.png'
        };
      }
      return null;
    } catch (e) {
      print('[CALL] Error getting sender info: $e');
      return null;
    }
  }

  void _setupCallEventListeners() {
    // Remove existing event listeners to avoid duplicates
    socket!.off('call_accepted');
    socket!.off('call_rejected');
    socket!.off('call_ended');
    socket!.off('incoming_call');
    socket!.off('direct_call');
    socket!.off('call_user');
    socket!.off('new_call');
    
    print('[CALL] Setting up call event listeners');
    
    // Listen for call accepted event
    socket!.on('call_accepted', (data) {
      print('[CALL] Call accepted: $data');
      
      // Hide calling dialog if shown
      Navigator.of(context).popUntil((route) => route.isFirst);
      
      // Show connected call UI with caller info from data
      String callerName = data['callerName'] ?? widget.doctorName;
      String callerAvatar = data['callerAvatar'] ?? widget.doctorAvatar;
      _showCallInProgressDialog(data['callId'], callerName, callerAvatar);
    });
    
    // Listen for call rejected event
    socket!.on('call_rejected', (data) {
      print('[CALL] Call rejected: $data');
      
      // Hide calling dialog if shown
      Navigator.of(context).popUntil((route) => route.isFirst);
      
      // Show rejection message
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Call was rejected'))
      );
    });
    
    // Listen for call ended event
    socket!.on('call_ended', (data) {
      print('[CALL] Call ended: $data');
      
      // Hide any call dialogs
      Navigator.of(context).popUntil((route) => route.isFirst);
      
      // Show call ended message
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Call ended'))
      );
    });
    
    // Listen for the standard incoming call event
    socket!.on('incoming_call', (data) {
      print('[CALL] Incoming call standard event: $data');
      _handleIncomingCall(data);
    });
    
    // Listen for direct calls (sent to user room)
    socket!.on('direct_call', (data) {
      print('[CALL] Direct call event received: $data');
      // Handle both formats - some implementations wrap in data field
      final callData = data is Map && data.containsKey('data') ? data['data'] : data;
      _handleIncomingCall(callData);
    });
    
    // Listen for generic call_user events
    socket!.on('call_user', (data) {
      print('[CALL] Call user event received: $data');
      _handleIncomingCall(data);
    });
    
    // Listen for new_call events (another common format)
    socket!.on('new_call', (data) {
      print('[CALL] New call event received: $data');
      _handleIncomingCall(data);
    });
    
    print('[CALL] Call event listeners setup complete');
  }

  // Handle incoming call event
  void _handleIncomingCall(Map<String, dynamic> data) {
    if (!mounted) return;
    
    final callerId = data['callerId'];
    final callerName = data['callerName'] ?? 'Unknown Caller';
    final callId = data['callId'];
    final callType = data['callType'] ?? 'audio';
    
    print("[SOCKET] Incoming call from $callerName (ID: $callerId), callId: $callId, type: $callType");
    
    // Show incoming call UI
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Text("Incoming ${callType.toString().capitalize()} Call"),
        content: Text("$callerName is calling you"),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _rejectCall(callId, callerId);
            },
            child: Text("Decline", style: TextStyle(color: Colors.red)),
          ),
          ElevatedButton(
            onPressed: () {
              Navigator.of(context).pop();
              _acceptCall(callId, callerId, callType);
            },
            child: Text("Accept"),
            style: ElevatedButton.styleFrom(
              backgroundColor: Colors.green,
              foregroundColor: Colors.white,
            ),
          ),
        ],
      ),
    );
  }

  void _showCallingDialog(String receiverId) {
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Text('Calling...'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            CircularProgressIndicator(),
            SizedBox(height: 16),
            Text('Calling ${widget.doctorName}'),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () {
              // Cancel the call
              Navigator.pop(context);
              
              // Emit call ended event
              socket!.emit('end_call', {
                'receiverId': receiverId,
              });
              
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(content: Text('Call cancelled'))
              );
            },
            child: Text('Cancel'),
          ),
        ],
      ),
    );
  }

  void _showIncomingCallDialog(dynamic data) {
    // Extract caller information from the data
    final callerId = data['callerId'];
    final callerName = data['callerName'] ?? 'Unknown Caller';
    final callerAvatar = data['callerAvatar'] ?? 'assets/images/avatar.png';
    final callId = data['callId'] ?? 'unknown_call';
    
    // For debugging
    print('[CALL] Showing incoming call from: $callerName (ID: $callerId)');
    
    // Play ringtone or additional haptic feedback
    HapticFeedback.heavyImpact();
    
    // Show dialog with fullscreen option for better visibility
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Text('Incoming Call'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            CircleAvatar(
              backgroundImage: AssetImage(callerAvatar),
              radius: 40,
            ),
            SizedBox(height: 16),
            Text(
              'Incoming call from $callerName',
              style: TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            ),
            SizedBox(height: 8),
            Text(
              'Call ID: $callId',
              style: TextStyle(
                fontSize: 12,
                color: Colors.grey,
              ),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () {
              // Reject the call
              socket!.emit('reject_call', {
                'callId': callId,
                'receiverId': callerId,
                'userId': _currentUserId,
              });
              
              Navigator.pop(context);
            },
            child: Text('Reject'),
            style: TextButton.styleFrom(
              backgroundColor: Colors.red,
              foregroundColor: Colors.white,
            ),
          ),
          TextButton(
            onPressed: () {
              // Accept the call
              socket!.emit('accept_call', {
                'callId': callId,
                'receiverId': callerId,
                'userId': _currentUserId,
              });
              
              Navigator.pop(context);
              
              // Show call in progress UI
              _showCallInProgressDialog(callId, callerName, callerAvatar);
            },
            child: Text('Accept'),
            style: TextButton.styleFrom(
              backgroundColor: Colors.green,
              foregroundColor: Colors.white,
            ),
          ),
        ],
      ),
    );
  }

  // Updated to include caller information
  void _showCallInProgressDialog(String callId, [String? callerName, String? callerAvatar]) {
    final displayName = callerName ?? widget.doctorName;
    final displayAvatar = callerAvatar ?? widget.doctorAvatar;
    
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Text('Call in Progress'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            CircleAvatar(
              backgroundImage: AssetImage(displayAvatar),
              radius: 40,
            ),
            SizedBox(height: 16),
            Text(displayName),
            Text('Call ID: $callId'),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () {
              // End the call
              socket!.emit('end_call', {
                'callId': callId,
              });
              
              Navigator.pop(context);
            },
            child: Text('End Call'),
            style: TextButton.styleFrom(
              backgroundColor: Colors.red,
              foregroundColor: Colors.white,
            ),
          ),
        ],
      ),
    );
  }

  // Diagnostic method to check connection and configuration
  Future<void> _diagnoseConnection() async {
    print("\n=== CONNECTION DIAGNOSTICS ===");
    
    // Check API configuration
    print("API Base URL: ${ApiConfig.baseUrl}");
    print("API Socket URL: ${ApiConfig.socketUrl}");
    
    // Check authentication
    final token = await storage.read(key: 'auth_token');
    final userId = await storage.read(key: 'user_id');
    print("Auth token available: ${token != null && token.isNotEmpty}");
    print("User ID available: ${userId != null && userId.isNotEmpty}");
    
    // Check socket service status
    final socketService = SocketService();
    print("Socket service initialized: ${socketService.isInitialized}");
    print("Socket connection status: ${socketService.currentConnectionStatus}");
    print("Socket is connected: ${socketService.isConnected}");
    
    // Try to get diagnostics
    try {
      final diagnostics = socketService.getDiagnosticInfo();
      print("Socket diagnostics: $diagnostics");
    } catch (e) {
      print("Error getting socket diagnostics: $e");
    }
    
    // Check server connectivity with a simple test request
    try {
      if (token != null && token.isNotEmpty) {
        final response = await http.get(
          Uri.parse('${ApiConfig.baseUrl}/health'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
        ).timeout(Duration(seconds: 5));
        
        print("API health check response: ${response.statusCode}");
      } else {
        print("Cannot check API health: No auth token available");
      }
    } catch (e) {
      print("API health check failed: $e");
    }
    
    print("=== END CONNECTION DIAGNOSTICS ===\n");
  }

  // Setup automatic refresh when messages are empty
  void _setupAutoRefresh() {
    // Cancel any existing timer
    _autoRefreshTimer?.cancel();
    
    // Create new refresh timer that checks if messages are empty
    _autoRefreshTimer = Timer.periodic(Duration(seconds: 5), (timer) {
      if (!mounted) {
        timer.cancel();
        return;
      }
      
      // Only auto-refresh if we have no messages and we're not currently loading
      if (_messages.isEmpty && !_isLoadingChat) {
        _autoRefreshAttempts++;
        print("[AUTO-REFRESH] Attempt $_autoRefreshAttempts to load messages");
        
        // Try to reconnect and fetch messages
        if (_autoRefreshAttempts <= 12) { // Limit to 1 minute of attempts (12 * 5 seconds)
          _attemptRefresh();
        } else {
          // After 1 minute of attempts, slow down to every 30 seconds
          if (_autoRefreshAttempts % 6 == 0) { // Every 30 seconds (6 * 5 seconds)
            _attemptRefresh();
          }
        }
      } else if (!_messages.isEmpty) {
        // If we have messages, we can stop the auto-refresh timer
        print("[AUTO-REFRESH] Messages loaded, stopping auto-refresh");
        timer.cancel();
        _autoRefreshTimer = null;
      }
    });
  }
  
  // Attempt to refresh the messages
  Future<void> _attemptRefresh() async {
    print("[AUTO-REFRESH] Attempting to refresh messages");
    
    // Check if socket is connected, try to reconnect if not
    final socketService = SocketService();
    if (!socketService.isConnected) {
      print("[AUTO-REFRESH] Socket not connected, attempting to reconnect");
      await socketService.reconnect();
    }
    
    // Fetch messages if we have a conversation ID
    if (widget.conversationId != null && widget.conversationId!.isNotEmpty) {
      await fetchMessages(widget.conversationId);
    } else if (_conversation != null && _conversation!.id.isNotEmpty) {
      await fetchMessages(_conversation!.id);
    } else {
      print("[AUTO-REFRESH] No conversation ID available for fetching messages");
    }
  }

  // Add this method to mark messages as read
  void _markMessagesAsRead() {
    try {
      if (socket != null && socket!.connected) {
        print("[CHAT] Marking messages as read for conversation: ${widget.conversationId}");
        socket!.emit('mark_messages_read', {
          'conversationId': widget.conversationId,
          'userId': _currentUserId,
        });
      } else {
        print("[CHAT] Socket not connected, cannot mark messages as read");
        // Try using HTTP instead
        _markMessagesAsReadViaHttp();
      }
    } catch (e) {
      print("[CHAT] Error marking messages as read: $e");
    }
  }
  
  // Fallback HTTP method to mark messages as read
  Future<void> _markMessagesAsReadViaHttp() async {
    try {
      final token = await storage.read(key: 'auth_token');
      if (token == null) return;
      
      final response = await http.post(
        Uri.parse('${ApiConfig.baseUrl}/messages/mark-read'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
        body: json.encode({
          'conversationId': widget.conversationId,
          'userId': _currentUserId,
        }),
      );
      
      if (response.statusCode == 200) {
        print("[CHAT] Successfully marked messages as read via HTTP");
      } else {
        print("[CHAT] Failed to mark messages as read via HTTP: ${response.statusCode}");
      }
    } catch (e) {
      print("[CHAT] HTTP error marking messages as read: $e");
    }
  }

  // Add this method to join chat room
  void _joinChatRoom() async {
    // Wait for user ID to be available
    if (_currentUserId == null) {
      await _getCurrentUserId();
    }
    
    if (_currentUserId == null || socket == null) {
      print("[CHAT] Cannot join chat room: user ID or socket not available");
      return;
    }
    
    // If we have a conversation ID, join that room
    if (widget.conversationId != null && widget.conversationId!.isNotEmpty) {
      print("[CHAT] Joining conversation room: ${widget.conversationId}");
      socket!.emit('join_conversation', {
        'conversationId': widget.conversationId,
        'userId': _currentUserId
      });
      
      // Start message polling for this conversation
      _startSocketPolling();
    }
  }

  // Initialize dedicated call socket
  Future<void> _initializeCallSocket() async {
    try {
      print("[CALL] Initializing dedicated call socket");
      
      // Get the auth token
      final prefs = await SharedPreferences.getInstance();
      final token = prefs.getString('auth_token');
      final userId = prefs.getString('user_id');
      
      if (token == null || userId == null) {
        print("[CALL ERROR] Cannot initialize call socket: missing token or userId");
        return;
      }
      
      print("[CALL] Creating socket with userId: $userId");
      
      // Create a dedicated socket just for calls
      callSocket = io.io(
        Constants.API_URL, 
        io.OptionBuilder()
          .setTransports(['websocket'])
          .disableAutoConnect()
          .setExtraHeaders({'Authorization': 'Bearer $token'})
          .setQuery({'userId': userId})
          .enableForceNew()
          .build()
      );
      
      // Set up connection event handlers with detailed logging
      callSocket!.onConnect((_) {
        print("[CALL] Call socket connected with id: ${callSocket!.id}");
        
        // Join user's room for call notifications
        _joinCallUserRoom(userId);
        
        // Set up call event listeners
        _setupDedicatedCallListeners();
      });
      
      callSocket!.onConnectError((error) {
        print("[CALL ERROR] Call socket connection error: $error");
      });
      
      callSocket!.onError((error) {
        print("[CALL ERROR] Call socket error: $error");
      });
      
      callSocket!.onDisconnect((reason) {
        print("[CALL] Call socket disconnected: $reason");
        
        // Attempt to reconnect after a delay if disconnected unexpectedly
        if (mounted && reason != "io client disconnect") {
          Future.delayed(Duration(seconds: 3), () {
            if (mounted && callSocket != null && !callSocket!.connected) {
              print("[CALL] Attempting to reconnect call socket");
              callSocket!.connect();
            }
          });
        }
      });
      
      // Connect the socket
      print("[CALL] Connecting call socket");
      callSocket!.connect();
      
      // Set a timeout to check if connection was successful
      Future.delayed(Duration(seconds: 5), () {
        if (mounted && callSocket != null && !callSocket!.connected) {
          print("[CALL WARNING] Call socket failed to connect within timeout");
          // Try reconnecting
          callSocket!.connect();
        }
      });
      
    } catch (e) {
      print("[CALL ERROR] Error initializing call socket: $e");
    }
  }

  // Join the user's room specifically for calls
  void _joinCallUserRoom(String userId) {
    if (callSocket == null || _currentUserId == null) return;
    
    print("[CALL] Joining call user room: $_currentUserId");
    callSocket!.emit('join_user_room', {'userId': _currentUserId});
    callSocket!.emit('register_for_calls', {'userId': _currentUserId});
  }

  // Setup all call-related socket listeners
  void _setupDedicatedCallListeners() {
    if (callSocket == null) {
      print("[SOCKET ERROR] Cannot setup call listeners - socket is null");
      return;
    }
  
    print("[SOCKET] Setting up call listeners...");
    
    // Listen for incoming calls
    callSocket!.on('incomingCall', (data) {
      print("[SOCKET] Received incoming call: $data");
      if (data != null) {
        _handleDedicatedCallIncomingCall(data);
      } else {
        print("[SOCKET ERROR] Received null incoming call data");
      }
    });
    
    // Listen for call accepted
    callSocket!.on('callAccepted', (data) {
      print("[SOCKET] Call accepted: $data");
      if (data != null) {
        _handleCallAccepted(data);
      }
    });
    
    // Listen for call rejected
    callSocket!.on('callRejected', (data) {
      print("[SOCKET] Call rejected: $data");
      if (data != null && mounted) {
        if (_callTimeoutTimer != null) {
          _callTimeoutTimer!.cancel();
          _callTimeoutTimer = null;
        }
        Navigator.of(context).pop(); // Close any calling dialog
        
        final reason = data['reason'] ?? 'Call was rejected';
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text(reason), duration: Duration(seconds: 2))
        );
        
        _resetPendingCallData();
      }
    });
    
    // Listen for call ended
    callSocket!.on('callEnded', (data) {
      print("[SOCKET] Call ended: $data");
      if (data != null) {
        _handleCallEnded(data);
      }
    });
    
    // Listen for call timeout
    callSocket!.on('callTimeout', (data) {
      print("[SOCKET] Call timed out: $data");
      if (data != null && mounted) {
        if (_callTimeoutTimer != null) {
          _callTimeoutTimer!.cancel();
          _callTimeoutTimer = null;
        }
        Navigator.of(context).pop(); // Close any calling dialog
        
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text("Call timed out. User may be unavailable."), duration: Duration(seconds: 2))
        );
        
        _resetPendingCallData();
      }
    });
    
    // Listen for ICE candidate
    callSocket!.on('iceCandidate', (data) {
      print("[SOCKET] Received ICE candidate: ${data != null ? 'valid data' : 'null data'}");
      if (data != null) {
        // Handle ICE candidate
      }
    });
    
    // Listen for SDP offer
    callSocket!.on('sdpOffer', (data) {
      print("[SOCKET] Received SDP offer: ${data != null ? 'valid data' : 'null data'}");
      if (data != null) {
        // Handle SDP offer
      }
    });
    
    // Listen for SDP answer
    callSocket!.on('sdpAnswer', (data) {
      print("[SOCKET] Received SDP answer: ${data != null ? 'valid data' : 'null data'}");
      if (data != null) {
        // Handle SDP answer
      }
    });
    
    print("[SOCKET] Call listeners setup complete");
  }
  
  // Handle incoming call event
  void _handleIncomingCall(Map<String, dynamic> data) {
    if (!mounted) return;
    
    final callerId = data['callerId'];
    final callerName = data['callerName'] ?? 'Unknown Caller';
    final callId = data['callId'];
    final callType = data['callType'] ?? 'audio';
    
    print("[SOCKET] Incoming call from $callerName (ID: $callerId), callId: $callId, type: $callType");
    
    // Show incoming call UI
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Text("Incoming ${callType.toString().capitalize()} Call"),
        content: Text("$callerName is calling you"),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _rejectCall(callId, callerId);
            },
            child: Text("Decline", style: TextStyle(color: Colors.red)),
          ),
          ElevatedButton(
            onPressed: () {
              Navigator.of(context).pop();
              _acceptCall(callId, callerId, callType);
            },
            child: Text("Accept"),
            style: ElevatedButton.styleFrom(
              backgroundColor: Colors.green,
              foregroundColor: Colors.white,
            ),
          ),
        ],
      ),
    );
  }
  
  // Accept incoming call
  void _acceptCall(String callId, String callerId, String callType) {
    print("[SOCKET] Accepting call: $callId from caller: $callerId");
    
    if (callSocket == null || !callSocket!.connected) {
      print("[SOCKET ERROR] Cannot accept call - socket not connected");
      _showErrorSnackbar("Connection issue. Please try again.");
      return;
    }
    
    final data = {
      'callId': callId,
      'callerId': callerId,
      'receiverId': widget.userId,
    };
    
    print("[SOCKET] Emitting acceptCall with data: $data");
    callSocket!.emit('acceptCall', data, (ack) {
      print("[SOCKET] Call acceptance acknowledgment: $ack");
    });
    
    // Navigate to call screen
    if (callType.toLowerCase() == 'video') {
      _navigateToVideoCallScreen(callerId, callId);
    } else {
      _navigateToAudioCallScreen(callerId, callId);
    }
  }
  
  // Reject incoming call
  void _rejectCall(String callId, String callerId) {
    print("[SOCKET] Rejecting call: $callId from caller: $callerId");
    
    if (callSocket == null || !callSocket!.connected) {
      print("[SOCKET ERROR] Cannot reject call - socket not connected");
      return;
    }
    
    final data = {
      'callId': callId,
      'callerId': callerId,
      'receiverId': widget.userId,
      'reason': 'Call rejected by user'
    };
    
    print("[SOCKET] Emitting rejectCall with data: $data");
    callSocket!.emit('rejectCall', data);
  }
  
  // Handle call accepted
  void _handleCallAccepted(Map<String, dynamic> data) {
    print("[SOCKET] Handling call accepted: $data");
    
    if (_callTimeoutTimer != null) {
      _callTimeoutTimer!.cancel();
      _callTimeoutTimer = null;
    }
    
    if (!mounted) return;
    
    final receiverId = data['receiverId'];
    final callId = data['callId'];
    
    // Dismiss calling dialog if showing
    Navigator.of(context).pop();
    
    // Navigate to appropriate call screen based on previously saved call type
    if (_pendingCallType.toLowerCase() == 'video') {
      _navigateToVideoCallScreen(receiverId, callId);
    } else {
      _navigateToAudioCallScreen(receiverId, callId);
    }
  }
  
  // Handle call ended
  void _handleCallEnded(Map<String, dynamic> data) {
    print("[SOCKET] Handling call ended: $data");
    // Any cleanup needed when call ends
    _resetPendingCallData();
  }
  
  // Navigate to audio call screen
  void _navigateToAudioCallScreen(String peerId, String callId) {
    print("[NAVIGATION] Navigating to audio call screen with peer: $peerId, callId: $callId");
    Navigator.of(context).push(
      MaterialPageRoute(
        builder: (context) => AudioCallScreen(
          callId: callId,
          peerId: peerId,
          socket: callSocket!,
          userId: widget.userId,
        ),
      ),
    );
  }
  
  // Navigate to video call screen  
  void _navigateToVideoCallScreen(String peerId, String callId) {
    print("[NAVIGATION] Navigating to video call screen with peer: $peerId, callId: $callId");
    Navigator.of(context).push(
      MaterialPageRoute(
        builder: (context) => VideoCallScreen(
          callId: callId,
          peerId: peerId,
          socket: callSocket!,
          userId: widget.userId,
        ),
      ),
    );
  }

  // Method to connect to the call socket with detailed logging and error handling
  void _connectCallSocket() {
    print("[SOCKET] Connecting to call socket...");
    
    try {
      // Check if we already have a socket instance
      if (callSocket != null) {
        if (callSocket!.connected) {
          print("[SOCKET] Call socket already connected");
          return;
        } else {
          print("[SOCKET] Call socket exists but disconnected, reconnecting...");
          callSocket!.connect();
          return;
        }
      }
      
      // Get socket manager instance
      final socketManager = SocketManager();
      
      // Initialize socket if not already initialized
      if (!socketManager.isInitialized()) {
        print("[SOCKET] Socket manager not initialized, initializing...");
        socketManager.initialize(
          baseUrl: baseUrl,
          token: userToken,
          userId: widget.userId,
        );
      }
      
      // Get socket instance from manager
      callSocket = socketManager.socket;
      
      if (callSocket == null) {
        print("[SOCKET ERROR] Failed to get socket instance from manager");
        _showErrorSnackbar("Connection issue. Please restart the app.");
        return;
      }
      
      print("[SOCKET] Call socket initialized, setting up call listeners");
      
      // Setup call listeners
      _setupDedicatedCallListeners();
      
      // Check connection status and log
      if (callSocket!.connected) {
        print("[SOCKET] Call socket connected immediately");
        // No need to handle this further, will be handled by the socket events
      } else {
        print("[SOCKET] Call socket not connected, waiting for connection events");
        // Connection will be handled by the event listeners
      }
    } catch (e) {
      print("[SOCKET ERROR] Error connecting to call socket: $e");
      _showErrorSnackbar("Connection issue. Please try again.");
    }
  }
  
  // Helper method to show error snackbar
  void _showErrorSnackbar(String message) {
    if (mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(message),
          backgroundColor: Colors.red.shade800,
          duration: Duration(seconds: 3),
        ),
      );
    }
  }

