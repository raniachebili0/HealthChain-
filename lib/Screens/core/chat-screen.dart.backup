                ],
              ),
            ),
          ],
        ),
        actions: _buildAppBarActions(),
      ),
      body: Stack(
        children: [
          Column(
            children: [
              // Time and notification indicator
              Container(
                padding: EdgeInsets.symmetric(vertical: 8, horizontal: 16),
                color: Colors.black,
                child: Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
