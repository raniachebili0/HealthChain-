                                                  senderName,
                                                  style: TextStyle(
                                                    fontWeight: FontWeight.bold,
                                                    color: isCurrentUser ? Colors.white : Colors.black87,
                                                    fontSize: 13,
                                                  ),
                                                ),
                                                SizedBox(width: 8),
                                                Text(
                                                  _formatTimestamp(message.createdAt),
                                                  style: TextStyle(
                                                    color: isCurrentUser ? Colors.white70 : Colors.black54,
                                                    fontSize: 11,
                                                  ),
                                                ),
                                                if (isTemporary) ...[
