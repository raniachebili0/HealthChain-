import 'package:flutter/material.dart';
import 'package:health_chain/utils/colors.dart';
import 'package:http/http.dart' as http;
import 'dart:convert';
import 'dart:math' as math;
import 'package:flutter_secure_storage/flutter_secure_storage.dart';
import 'package:socket_io_client/socket_io_client.dart' as io;
import 'dart:async';
import 'package:flutter/services.dart';
import '../../config/api_config.dart';
import '../../Widgets/notification_badge.dart';
import '../../services/socket_service.dart';
import 'package:health_chain/models/user.dart';
import 'package:health_chain/models/conversation.dart';
import 'package:health_chain/models/message.dart';
import 'package:flutter/services.dart';
import 'package:shared_preferences/shared_preferences.dart';
import 'package:health_chain/Screens/calling-screen.dart';
import 'package:health_chain/services/socket_manager.dart';



class ChatScreen extends StatefulWidget {
  final String? conversationId;
  final String doctorName;
  final String doctorAvatar;
  
  const ChatScreen({
    super.key, 
    this.conversationId,
    this.doctorName = "Dr. Marcus Horizon", 
    this.doctorAvatar = "assets/images/doctor.png"
  });

  @override
  State<ChatScreen> createState() => _ChatScreenState();
}

class _ChatScreenState extends State<ChatScreen> {
  final TextEditingController _controller = TextEditingController();
  final ScrollController _scrollController = ScrollController();
  final storage = FlutterSecureStorage();
  List<User> _users = [];
  Conversation? _conversation;
  List<Message> _messages = [];
  bool _isLoadingUsers = false;
  bool _isLoadingChat = true;
  String? _currentUserId;
  io.Socket? socket;
  Map<String, bool> _typingUsers = {};
  
  Timer? _refreshTimer;
  Set<String> _messageIds = {};
  bool _showNotificationBanner = false;
  Message? _notificationMessage;
  DateTime _lastHttpRefresh = DateTime.now(); // Track last HTTP refresh to prevent spam
  int _markAsReadErrorCount = 0; // Track consecutive errors for mark as read

  // Timer for auto-refresh
  Timer? _autoRefreshTimer;
  int _autoRefreshAttempts = 0;
  
  // SOCKET DEDICATED TO CALLS
  io.Socket? callSocket;
  AlertDialog? _currentCallDialog;
  String pendingCallId = '';
  String pendingCallReceiverId = '';
  String pendingCallReceiverName = '';
  String pendingCallType = '';
  Map<String, dynamic> currentCallData = {};
  Timer? _callTimeoutTimer;

  @override
  void initState() {
    super.initState();
    _loadUserIdFromStorage().then((value) {
      setState(() {
        _isLoading = true;
      });
      // Initialize the call socket
      _initializeCallSocket();
      // Initialize the socket
      socketService.initializeSocket();
      socketService.socketInstance!.auth = {
        'token': _authToken,
      };
      
      // Keep track of socket connection status
      socketService.connectionStatusStream.listen((status) {
        if (mounted) {
          setState(() {
            _isSocketConnected = status == ConnectionStatus.connected;
            if (_isSocketConnected) {
              // Register socket events when connected
              _registerSocketEvents();
              if (_conversation != null) {
                _joinConversationRoom(_conversation!.id);
              }
            }
          });
        }
      });

      // Load conversation if we have an ID
      if (widget.conversationId != null) {
        _loadConversation(widget.conversationId!);
      }
    });
    
    // Connect to call socket with detailed logging
    _connectCallSocket();
    
    // Add this line to setup dedicated call listeners
    _setupDedicatedCallListeners();
  }
  
  @override
  void dispose() {
    // Clean up all timers
    _messageRefreshTimer?.cancel();
    _typingTimer?.cancel();
    _refreshConversationsTimer?.cancel();
    
    // Clean up sockets
    if (socketService.socketInstance != null) {
      // Leave the room when component unmounts
      if (_conversation != null) {
        socketService.socketInstance!.emit('leave_conversation', {
          'conversationId': _conversation!.id,
        });
      }
      
      // Remove event listeners
      socketService.socketInstance!.off('new_message');
      socketService.socketInstance!.off('typing');
      socketService.socketInstance!.off('stop_typing');
      socketService.socketInstance!.off('call_accepted');
      socketService.socketInstance!.off('call_rejected');
      socketService.socketInstance!.off('call_timeout');
      socketService.socketInstance!.off('call_ended');
    }
    
    // Clean up dedicated call socket
    if (callSocket != null) {
      callSocket!.off('incoming_call');
      callSocket!.off('call_request');
      callSocket!.disconnect();
      callSocket = null;
      print("[CALL] Call socket disposed");
    }
    
    super.dispose();
  }

  Future<void> _initializeApp() async {
    // First, make sure we have the current user ID
    await _getCurrentUserId();
    
    if (_currentUserId == null || _currentUserId!.isEmpty) {
      print("Failed to get current user ID during initialization");
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Please log in to use the chat feature'))
      );
      return;
    }
    
    print("Initializing chat with user ID: $_currentUserId");
    
    // Use SocketService instead of direct socket connection
    await _initializeSocketConnection();
    
    // If conversation ID is provided, load the conversation and messages
    if (widget.conversationId != null && widget.conversationId!.isNotEmpty) {
      await _loadConversation(widget.conversationId!);
    } else {
      setState(() {
        _isLoadingChat = false;
      });
      print("No conversation ID provided");
    }
    
    // Set up a timer to refresh messages periodically
    _startMessageRefreshTimer();
    
    // Safety timeout to prevent stuck loading state
    Future.delayed(Duration(seconds: 10), () {
      if (mounted && _isLoadingChat) {
        print("Safety timeout: Forcing loading state to false after 10 seconds");
        setState(() {
          _isLoadingChat = false;
        });
      }
    });
  }
  
  Future<void> _initializeSocketConnection() async {
    try {
      // Use the SocketService singleton
      SocketService socketService = SocketService();
      await socketService.initializeSocket();
      
      // Get the socket instance from the service
      socket = socketService.socket;
      
      if (socket != null) {
        print("[CHAT] Socket obtained from SocketService");
        
        // Register for socket events
        _registerSocketEvents();
        
        // Register for call events immediately
        _setupCallEventListeners();
        
        // Join user's room to receive incoming calls
        _joinUserRoom();
      } else {
        print("[CHAT] Failed to get socket from SocketService");
      }
    } catch (e) {
      print("Error initializing socket connection: $e");
    }
  }
  
  // Join the user's room to receive direct notifications including calls
  void _joinUserRoom() {
    if (socket == null || _currentUserId == null) {
      print("[CHAT] Cannot join user room: socket not connected or user ID missing");
      return;
    }
    
    // Check if we have user ID
    if (_currentUserId == null || _currentUserId!.isEmpty) {
      print("[CHAT] Cannot join user room: user ID is empty");
      _getCurrentUserId().then((_) {
        if (_currentUserId != null && _currentUserId!.isNotEmpty) {
          _joinUserRoomAfterIdCheck();
        }
      });
      return;
    }

    _joinUserRoomAfterIdCheck();
  }

  // Helper method after user ID check
  void _joinUserRoomAfterIdCheck() {
    if (socket == null || _currentUserId == null) return;
    
    // First ensure we're connected
    if (!socket!.connected) {
      print("[CHAT] Socket not connected, attempting to connect before joining room");
      socket!.connect();
      
      // Wait for connection and then join
      socket!.onConnect((_) {
        _emitJoinUserRoom();
      });
      return;
    }
    
    // Already connected, join immediately
    _emitJoinUserRoom();
  }

  // Emit the join_user_room event
  void _emitJoinUserRoom() {
    print("[CHAT] Joining user room for userId: $_currentUserId");
    
    // Join the personal room for direct communication
    socket!.emit('join_user_room', {'userId': _currentUserId});
    
    // Also join a room named after the user ID for compatibility with some socket systems
    socket!.emit('join', {'room': _currentUserId});
    
    // Debug message to confirm join attempt
    print("[CHAT] Emit: join_user_room and join with userId: $_currentUserId");
  }

  void _registerSocketEvents() {
    if (socket == null) return;
    
    socket!.onConnect((_) {
      print('[CHAT] Socket connected successfully in chat screen');
      
      // Set up call listeners immediately when socket connects
      _setupCallEventListeners();
      
      // Join the user's room to receive direct messages and calls
      _joinUserRoom();
      
      // Join conversation room if we have a conversation ID
      if (widget.conversationId != null && widget.conversationId!.isNotEmpty) {
        print('[CHAT] Joining conversation room: ${widget.conversationId}');
        socket!.emit('join_conversation', {
          'conversationId': widget.conversationId,
          'userId': _currentUserId
        });
        
        // Also join any loaded conversation
        if (_conversation != null && _conversation!.id != widget.conversationId) {
          print('[CHAT] Joining additional conversation room: ${_conversation!.id}');
          socket!.emit('join_conversation', {
            'conversationId': _conversation!.id,
            'userId': _currentUserId
          });
        }
        
        // Start message polling using socket
        _startSocketPolling();
      } else if (_conversation != null) {
        print('[CHAT] Joining conversation room: ${_conversation!.id}');
        socket!.emit('join_conversation', {
          'conversationId': _conversation!.id,
          'userId': _currentUserId
        });
        
        // Start message polling using socket
        _startSocketPolling();
      } else {
        print('[CHAT] No conversation to join');
      }
      
      // Emit a presence event to let others know we're online
      if (_currentUserId != null) {
        socket!.emit('user_online', {'userId': _currentUserId});
        print('[CHAT] Emitted user_online for $_currentUserId');
      }
    });

    socket!.on('new_message', (data) {
      print('Received new message event from socket');
      if (data != null && data['message'] != null) {
        print('Message data: ${data['message']}');
        try {
          final message = Message.fromJson(data['message']);
          
          // Check if this message already exists in our list
          if (message.id.isEmpty) {
            print('Ignored message with empty ID');
            return;
          }
          
          // Skip temporary messages from the socket response
          if (message.id.contains('_temp')) {
            print('Ignored temporary message from socket');
            return;
          }
          
          // More robust duplicate detection by ID
          if (_messageIds.contains(message.id)) {
            print('Ignored duplicate message with ID: ${message.id}');
            return;
          }
          
          // Enhanced duplicate detection for messages with same content
          final similiarMessages = _messages.where((msg) => 
            msg.content == message.content &&
            msg.senderId == message.senderId &&
            !msg.id.contains('_temp') &&
            DateTime.now().difference(msg.createdAt).inSeconds < 10
          ).toList();
          
          if (similiarMessages.isNotEmpty) {
            print('Ignored duplicate message with similar content sent within the last 10 seconds');
            return;
          }
          
          // Handle our own messages differently from others' messages
          if (message.senderId == _currentUserId) {
            // This is our own message - check if we already have a temp version of it
            final tempIndices = _messages.where((msg) => 
              msg.id.contains('_temp') && 
              msg.content == message.content &&
              msg.senderId == _currentUserId &&
              DateTime.now().difference(msg.createdAt).inMinutes < 2
            ).toList();
            
            if (tempIndices.isNotEmpty) {
              print('Received confirmation of our own recent message: ${message.content}');
              
              // If we have a temporary version, update it instead of adding a duplicate
              setState(() {
                // Only keep the first temp message and replace it with the real one
                if (tempIndices.length > 1) {
                  // Remove all but the first temp message
                  for (int i = 1; i < tempIndices.length; i++) {
                    int idx = _messages.indexOf(tempIndices[i]);
                    if (idx >= 0) {
                      _messageIds.remove(_messages[idx].id);
                      _messages.removeAt(idx);
                    }
                  }
                }
                
                // Replace the remaining temp message with the real one
                final idx = _messages.indexOf(tempIndices[0]);
                if (idx >= 0) {
                  _messageIds.remove(_messages[idx].id);
                  _messages[idx] = message;
                  _messageIds.add(message.id);
                }
              });
              return; // Skip adding a new message
            }
          }
          
          // If it passes all checks, it's a new message to add
          setState(() {
            _messages.add(message);
            _messageIds.add(message.id);
            _messages.sort((a, b) => a.createdAt.compareTo(b.createdAt));
            
            // Give immediate feedback for new messages from others
            if (message.senderId != _currentUserId) {
              // Request haptic feedback for a stronger notification
              HapticFeedback.mediumImpact();
              
              // Show notification banner for new messages when user is not at bottom
              showNotificationBanner(message);
            }
          });
          
          print('Added new message from ${message.sender?.name ?? "Unknown"}: ${message.content}');
          
          // Play notification sound and vibrate for messages from others
          if (message.senderId != _currentUserId) {
            // Scroll to the bottom after adding the new message
            _scrollToBottom();
          } else {
            // For our own messages, mark as read and scroll
            _scrollToBottom();
          }
        } catch (e) {
          print('Error parsing message data: $e');
        }
      } else {
        print('Invalid message data received');
      }
    });
    
    socket!.on('message_notification', (data) {
      print('Received message notification');
      if (data != null && data['message'] != null) {
        try {
          final message = Message.fromJson(data['message']);
          final conversationId = data['conversationId'];
          
          // Only provide subtle vibration feedback 
          if (_conversation == null || _conversation!.id != conversationId) {
            HapticFeedback.lightImpact();
            
            // Show a system notification banner for messages from other conversations
            if (message.senderId != _currentUserId) {
              // Display notification for messages from other conversations
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                  content: Row(
                    children: [
                      CircleAvatar(
                        backgroundImage: AssetImage(_getParticipantAvatar(message.senderId)),
                        radius: 14,
                      ),
                      SizedBox(width: 8),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          mainAxisSize: MainAxisSize.min,
                          children: [
                            Text(
                              _getParticipantName(message.senderId),
                              style: TextStyle(fontWeight: FontWeight.bold),
                            ),
                            Text(
                              message.content,
                              style: TextStyle(fontSize: 12),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                  duration: Duration(seconds: 3),
                  behavior: SnackBarBehavior.floating,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(10),
                  ),
                  action: SnackBarAction(
                    label: 'VIEW',
                    onPressed: () {
                      // Navigate to the conversation
                      Navigator.push(
                        context,
                        MaterialPageRoute(
                          builder: (context) => ChatScreen(
                            conversationId: conversationId,
                          ),
                        ),
                      );
                    },
                  ),
                ),
              );
            }
          } else {
            // Show notification for messages in the current conversation
            if (message.senderId != _currentUserId) {
              showNotificationBanner(message);
            }
          }
        } catch (e) {
          print('Error processing notification: $e');
        }
      }
    });
    
    socket!.on('messages_update', (data) {
      print('Received messages_update from socket polling');
      // Check if component is still mounted before processing update
      if (!mounted) {
        print('[CHAT] Component unmounted, ignoring messages_update event');
        return;
      }
      
      if (data != null && data['messages'] != null && data['conversationId'] != null) {
        try {
          if (_conversation != null && _conversation!.id == data['conversationId']) {
            final List<dynamic> messageList = data['messages'];
            final List<Message> updatedMessages = [];
            Set<String> updatedMessageIds = {};
            
            // Parse all messages
            for (final msgData in messageList) {
              try {
                final msg = Message.fromJson(msgData);
                if (msg.id.isNotEmpty && !msg.id.contains('_temp')) {
                  updatedMessages.add(msg);
                  updatedMessageIds.add(msg.id);
                }
              } catch (e) {
                print('Error parsing message in update: $e');
              }
            }
            
            // Only update if we have new messages (that aren't already in our tracked IDs)
            final Set<String> newMessageIds = updatedMessageIds.difference(_messageIds);
            if (newMessageIds.isNotEmpty) {
              print('Adding ${newMessageIds.length} new messages from update');
              
              // Check if component is still mounted before calling setState
              if (mounted) {
                setState(() {
                  // Keep only temporary messages that might not be on server yet
                  final tempMessages = _messages.where((msg) => msg.id.contains('_temp')).toList();
                  
                  // Build a list of all messages we know about
                  final allMessages = <Message>[];
                  
                  // First, add existing messages we want to keep
                  for (final msg in _messages) {
                    // Keep if it's a temp message or it's in the updated messages list
                    if (msg.id.contains('_temp') || updatedMessageIds.contains(msg.id)) {
                      allMessages.add(msg);
                    }
                  }
                  
                  // Then add any new messages that weren't in our list
                  for (final msg in updatedMessages) {
                    if (!_messageIds.contains(msg.id)) {
                      allMessages.add(msg);
                    }
                  }
                  
                  // Update our tracked state
                  _messages = allMessages;
                  _messageIds = {...updatedMessageIds, ...tempMessages.map((msg) => msg.id).toSet()};
                  
                  // Sort messages
                  _messages.sort((a, b) => a.createdAt.compareTo(b.createdAt));
                });
                
                // Scroll to bottom after updating messages
                _scrollToBottom();
              } else {
                print('[CHAT] Component unmounted, skipping setState in messages_update');
              }
            } else {
              print('No new messages in update');
            }
          }
        } catch (e) {
          print('Error processing messages update: $e');
        }
      }
    });
  }

  Future<void> _getCurrentUserId() async {
    try {
      // Try to get user_id directly (from user_id storage key)
      final userId = await storage.read(key: 'user_id');
      if (userId != null && userId.isNotEmpty) {
        setState(() {
          _currentUserId = userId;
        });
        print("Current user ID retrieved from user_id: $_currentUserId");
        return;
      }
      
      // As fallback, try to get from user object if it exists
      final userJson = await storage.read(key: 'user');
      if (userJson != null) {
        final userData = json.decode(userJson);
        if (userData['_id'] != null && userData['_id'].toString().isNotEmpty) {
          setState(() {
            _currentUserId = userData['_id'];
          });
          print("Current user ID retrieved from user object: $_currentUserId");
          
          // Save it to user_id for future reference
          await storage.write(key: 'user_id', value: _currentUserId);
          return;
        }
      }
      
      print("No user ID found in secure storage, trying to get it from token");
      
      // Last resort: try to get from token
      final token = await storage.read(key: 'auth_token');
      if (token != null && token.isNotEmpty) {
        try {
          // Call the backend to get user information
          final response = await http.get(
            Uri.parse('${ApiConfig.baseUrl}/users/me'),
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer $token',
            },
          );
          
          if (response.statusCode == 200) {
            final userData = json.decode(response.body);
            if (userData['_id'] != null) {
              setState(() {
                _currentUserId = userData['_id'];
              });
              // Save it for future reference
              await storage.write(key: 'user_id', value: _currentUserId);
              print("Current user ID retrieved from API: $_currentUserId");
              return;
            }
          } else {
            print("Failed to get user information from API: ${response.statusCode}");
          }
        } catch (e) {
          print("Error fetching user information from API: $e");
        }
      }
      
      print("All methods to get user ID failed");
    } catch (e) {
      print("Error getting current user: $e");
    }
  }

  // Alias for _getCurrentUserId to match the call in initState
  Future<void> _getCurrentUser() async {
    await _getCurrentUserId();
  }

  void _startSocketPolling() {
    if (socket == null) {
      print('Cannot start polling: socket is null');
        return;
      }

    // Tell the server to start sending us updates for the current conversation
    if (_conversation != null) {
      print('Starting message polling via socket for: ${_conversation!.id}');
      socket?.emit('start_messages_polling', {
        'conversationId': _conversation!.id,
        'interval': 2000 // Refresh more frequently (every 2 seconds)
      });
      
      // Also immediately request a full update to ensure we have the latest messages
      socket?.emit('request_messages_update', {
            'conversationId': _conversation!.id,
            'userId': _currentUserId
          });
    }
    
    // Also poll for the widget's conversation if different
    if (widget.conversationId != null && 
        widget.conversationId!.isNotEmpty && 
        (_conversation == null || widget.conversationId != _conversation!.id)) {
      print('Starting additional message polling for: ${widget.conversationId}');
      socket?.emit('start_messages_polling', {
        'conversationId': widget.conversationId,
        'interval': 2000 // Refresh more frequently (every 2 seconds)
      });
      
      // Also immediately request a full update for this conversation
      socket?.emit('request_messages_update', {
        'conversationId': widget.conversationId,
        'userId': _currentUserId
      });
    }
  }

  void _startMessageRefreshTimer() {
    // Cancel any existing timer
    _refreshTimer?.cancel();
    
    // Get SocketService to monitor connection status properly
    final SocketService socketService = SocketService();
    
    // Counter for consecutive HTTP fallbacks to prevent infinite loops
    int consecutiveHttpFallbacks = 0;
    final int maxConsecutiveHttpFallbacks = 5;
    
    // Set up a new timer for less frequent refreshes (every 5 seconds instead of 1)
    // This prevents excessive HTTP calls when socket is disconnected
    _refreshTimer = Timer.periodic(Duration(seconds: 5), (timer) {
      // Check if still mounted before proceeding
      if (!mounted) {
        print('[CHAT] Component unmounted, cancelling refresh timer');
        timer.cancel();
        return;
      }
      
      if (_conversation != null) {
        // Only refresh via HTTP if we've waited at least 5 seconds since last refresh
        // This prevents rapid consecutive HTTP calls
        if (DateTime.now().difference(_lastHttpRefresh).inSeconds >= 5) {
          // Check if socket is connected using the public getter
          bool isSocketConnected = socketService.isConnected;
          
          if (isSocketConnected) {
            // Socket is connected, use socket for real-time updates
            socketService.emit('request_messages_update', {
              'conversationId': _conversation!.id,
              'userId': _currentUserId
            });
            consecutiveHttpFallbacks = 0; // Reset counter on successful socket usage
          } else {
            // Fall back to HTTP polling if socket is not connected
            consecutiveHttpFallbacks++;
            
            if (consecutiveHttpFallbacks <= maxConsecutiveHttpFallbacks) {
              print('[CHAT] Socket not connected, using HTTP to refresh conversations (attempt $consecutiveHttpFallbacks/$maxConsecutiveHttpFallbacks)');
              _lastHttpRefresh = DateTime.now(); // Update timestamp to prevent spam
              fetchMessages(_conversation!.id);
              
              // Check socket manager diagnostics to troubleshoot connection issues
              _logSocketDiagnostics(socketService);
              
              // Attempt to reconnect the socket
              socketService.reconnect();
            } else {
              print('[CHAT] Too many consecutive HTTP fallbacks ($consecutiveHttpFallbacks). Pausing refresh timer for 30 seconds.');
              
              // Pause the timer for 30 seconds to give the socket time to recover
              timer.cancel();
              
              // Display a user-friendly message
              if (mounted) {
                ScaffoldMessenger.of(context).showSnackBar(
                  SnackBar(
                    content: Text('Network connection issues detected. Trying to reconnect...'),
                    duration: Duration(seconds: 5),
                  )
                );
              }
              
              // Try one more aggressive reconnection
              _attemptAggressiveReconnection(socketService);
              
              // Restart the timer after a pause to allow connection recovery
              Future.delayed(Duration(seconds: 30), () {
                if (mounted) {
                  consecutiveHttpFallbacks = 0; // Reset counter
                  _startMessageRefreshTimer(); // Restart timer with fresh state
                }
              });
            }
          }
        }
      }
    });
  }
  
  // Helper method to log socket diagnostics
  void _logSocketDiagnostics(SocketService socketService) {
    try {
      final diagnostics = socketService.getDiagnosticInfo();
      print('[CHAT] Socket diagnostic info:');
      diagnostics.forEach((key, value) {
        print('  $key: $value');
      });
    } catch (e) {
      print('[CHAT] Unable to get socket diagnostics: $e');
    }
  }
  
  // Attempt an aggressive reconnection strategy
  Future<void> _attemptAggressiveReconnection(SocketService socketService) async {
    print('[CHAT] Attempting aggressive socket reconnection');
    
    try {
      // First, try to get a fresh auth token if possible
      final storage = FlutterSecureStorage();
      final token = await storage.read(key: 'auth_token');
      final userId = await storage.read(key: 'user_id');
      
      if (token != null && userId != null) {
        print('[CHAT] Reinitializing socket with fresh credentials');
        await socketService.reinitializeWithCredentials(token, userId);
      } else {
        print('[CHAT] Missing credentials for aggressive reconnection');
        await socketService.reconnect();
      }
    } catch (e) {
      print('[CHAT] Error during aggressive reconnection: $e');
    }
  }

  Future<void> _loadConversation(String conversationId) async {
    setState(() {
      _isLoadingChat = true;
    });
    
    try {
      final token = await storage.read(key: 'auth_token');
      if (token == null) {
        print("No auth token found");
        setState(() {
          _isLoadingChat = false;
        });
        return;
      }
      
      // Get conversation details
      final conversationResponse = await http.get(
        Uri.parse('${ApiConfig.baseUrl}/messages/conversations/$conversationId'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
      );
      
      if (conversationResponse.statusCode == 200) {
        final conversationData = json.decode(conversationResponse.body);
        setState(() {
          _conversation = Conversation.fromJson(conversationData);
        });
        
        // Make sure to join the conversation room via socket
        if (socket?.connected == true) {
          print('Joining conversation room after loading: ${conversationId}');
          socket?.emit('join_conversation', {
            'conversationId': conversationId,
            'userId': _currentUserId
          });
          
          // Start message polling
          _startSocketPolling();
        }
        
        // Now fetch messages for this conversation
        await fetchMessages(conversationId);
        
        // Mark all messages as read
        await markMessagesAsRead(conversationId);
      } else {
        print("Failed to load conversation: ${conversationResponse.statusCode}");
        setState(() {
          _isLoadingChat = false;
        });
      }
    } catch (e) {
      print("Error loading conversation: $e");
      setState(() {
        _isLoadingChat = false;
      });
    } finally {
      // Ensure loading state is turned off even if there's an uncaught exception
      if (mounted) {
        setState(() {
          _isLoadingChat = false;
        });
      }
    }
  }

  Future<void> fetchUsers() async {
    setState(() {
      _isLoadingUsers = true;
    });
    
    try {
      final token = await storage.read(key: 'auth_token');
      if (token == null) {
        print("No auth token found");
        setState(() {
          _isLoadingUsers = false;
        });
        return;
      }
      
      final response = await http.get(
        Uri.parse('${ApiConfig.baseUrl}/users/all'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
      ).timeout(Duration(seconds: 10));
      
      if (response.statusCode == 200) {
        final List<dynamic> data = json.decode(response.body);
        setState(() {
          _users = data.map((user) => User.fromJson(user)).toList();
          _isLoadingUsers = false;
        });
      } else {
        print("Failed to load users: ${response.statusCode}");
        setState(() {
          _isLoadingUsers = false;
        });
      }
    } catch (e) {
      print("Error fetching users: $e");
      setState(() {
        _isLoadingUsers = false;
      });
    }
  }

  Future<void> fetchMessages([String? conversationId]) async {
    // Avoid concurrent fetches by checking if we're already loading
    if (_isLoadingChat) {
      print("Already fetching messages, skipping this request");
      return;
    }
    
    print("=== FETCH MESSAGES DEBUG ===");
    print("Starting fetchMessages with conversationId: ${conversationId ?? 'null'}");
    
    setState(() {
      _isLoadingChat = true;
    });
    
    try {
      if (_currentUserId == null || _currentUserId!.isEmpty) {
        print("No current user ID found when fetching messages, trying to retrieve it");
        await _getCurrentUserId();
        
        if (_currentUserId == null || _currentUserId!.isEmpty) {
          print("Still unable to get current user ID");
          setState(() {
            _isLoadingChat = false;
          });
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text('Unable to load messages: User ID not found'))
          );
          return;
        }
      }

      print("Fetching messages with user ID: $_currentUserId");
      
      final token = await storage.read(key: 'auth_token');
      print("Auth token available: ${token != null && token.isNotEmpty}");
      
      if (token == null || token.isEmpty) {
        print("No auth token found when fetching messages");
        setState(() {
          _isLoadingChat = false;
        });
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Unable to load messages: Not authenticated'))
        );
        return;
      }
      
      // Use the provided conversationId or fall back to the current conversation's id
      final String convoId = conversationId ?? _conversation?.id ?? '';
      print("Using conversation ID: $convoId");
      
      if (convoId.isEmpty) {
        print("No conversation ID available for fetching messages");
        setState(() {
          _isLoadingChat = false;
        });
        return;
      }
      
      print("Fetching messages for conversation: $convoId with user: $_currentUserId");
      print("API URL: ${ApiConfig.baseUrl}/messages/conversations/$convoId/messages?userId=$_currentUserId");
      
      try {
        final response = await http.get(
          Uri.parse('${ApiConfig.baseUrl}/messages/conversations/$convoId/messages?userId=$_currentUserId'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
        ).timeout(Duration(seconds: 10));
        
        print("API response status code: ${response.statusCode}");
        
        if (response.statusCode == 200) {
          print("Response body: ${response.body.substring(0, math.min(100, response.body.length))}...");
          
          final List<dynamic> data = json.decode(response.body);
          print("Successfully fetched ${data.length} messages from API");
          
          // Create a proper List<Message> by carefully handling each message
          final List<Message> messages = [];
          int validMessageCount = 0;
          int invalidMessageCount = 0;
          
          for (var msgData in data) {
            try {
              final msg = Message.fromJson(msgData);
              // Only add valid messages with non-empty content
              if (msg.id.isNotEmpty) {
                messages.add(msg);
                validMessageCount++;
              } else {
                invalidMessageCount++;
                print("Skipping message with empty ID: $msgData");
              }
            } catch (parseError) {
              invalidMessageCount++;
              print("Error parsing message: $parseError");
              print("Problematic message data: $msgData");
            }
          }
          
          print("Processed $validMessageCount valid messages, skipped $invalidMessageCount invalid messages");
          
          // Sort messages by creation time (most recent last)
          messages.sort((a, b) => a.createdAt.compareTo(b.createdAt));
          
          // Store existing message IDs to check for duplicates when receiving socket messages
          _messageIds = messages.map((msg) => msg.id).toSet();
          
          print("Message count after sorting: ${messages.length}");
          if (messages.isNotEmpty) {
            print("First message: ${messages.first.content}");
            print("Last message: ${messages.last.content}");
          } else {
            print("No messages returned from API - this may be normal for a new conversation");
          }
          
          // Make sure we're updating the UI on the main thread
          if (mounted) {
            setState(() {
              _messages = messages;
              _isLoadingChat = false;
            });
            
            if (_messages.isNotEmpty) {
              print("Setting state with ${_messages.length} messages");
              // Ensure we scroll to the bottom after messages are loaded
              WidgetsBinding.instance.addPostFrameCallback((_) {
                _scrollToBottom();
              });
            } else {
              print("No messages to display after processing");
            }
          }
          
          // After loading the messages, mark them as read immediately
          // This ensures the notification badges are removed for the current conversation
          await markMessagesAsRead(convoId);
        } else {
          print("Failed to load messages: ${response.statusCode}");
          print("Response body: ${response.body}");
          if (mounted) {
            setState(() {
              _isLoadingChat = false;
            });
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(content: Text('Failed to load messages: Server error'))
            );
          }
        }
      } catch (e) {
        print("Error fetching messages: $e");
        if (mounted) {
          setState(() {
            _isLoadingChat = false;
          });
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text('Failed to load messages: ${e.toString().substring(0, math.min(e.toString().length, 50))}...'))
          );
        }
      }
    } catch (e) {
      print("Error in fetchMessages: $e");
      if (mounted) {
        setState(() {
          _isLoadingChat = false;
        });
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Failed to load messages: ${e.toString().substring(0, math.min(e.toString().length, 50))}...'))
        );
      }
    } finally {
      // Ensure loading state is always turned off even if there's an uncaught exception
      if (mounted) {
        Future.delayed(Duration(seconds: 1), () {
          setState(() {
            _isLoadingChat = false;
          });
          print("=== END FETCH MESSAGES DEBUG ===");
        });
      }
    }
  }

  Future<void> markMessagesAsRead(String conversationId) async {
    try {
      // If we've seen too many consecutive 404 errors, stop trying to mark as read
      if (_markAsReadErrorCount >= 3) {
        print("Skipping markMessagesAsRead due to repeated 404 errors");
        return;
      }
      
      if (_currentUserId == null || _currentUserId!.isEmpty) {
        print("No current user ID found when marking messages as read");
        return;
      }

      final token = await storage.read(key: 'auth_token');
      if (token == null || token.isEmpty) {
        print("No auth token found when marking messages as read");
        return;
      }
      
      print("Marking messages as read for conversation: $conversationId");
      
      // Make API call to mark messages as read
      final response = await http.post(
        Uri.parse('${ApiConfig.baseUrl}/messages/conversations/$conversationId/read'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
        body: json.encode({
          'userId': _currentUserId,
        }),
      );
      
      if (response.statusCode == 200) {
        print("Successfully marked messages as read");
        _markAsReadErrorCount = 0; // Reset error count on success
        
        // Demander au serveur d'envoyer une mise à jour des conversations
        // Cela va automatiquement mettre à jour l'écran des conversations
        socket?.emit('request_conversations_update', {
          'userId': _currentUserId
        });
        
        // Émettre un événement pour informer qu'on a lu des messages
        socket?.emit('message_read', {
          'conversationId': conversationId,
          'userId': _currentUserId
        });
        
        // Update UI to reflect read status
        setState(() {
          // Update all messages from other users to read=true
          for (int i = 0; i < _messages.length; i++) {
            if (_messages[i].senderId != _currentUserId && !_messages[i].read) {
              // Create a copy of the message with read=true
              _messages[i] = Message(
                id: _messages[i].id,
                senderId: _messages[i].senderId,
                content: _messages[i].content,
                createdAt: _messages[i].createdAt,
                conversationId: _messages[i].conversationId,
                read: true,
                readAt: DateTime.now(),
                sender: _messages[i].sender,
              );
            }
          }
        });
      } else {
        print("Failed to mark messages as read: ${response.statusCode}");
        
        // Increment error count for 404 errors
        if (response.statusCode == 404) {
          _markAsReadErrorCount++;
          if (_markAsReadErrorCount >= 3) {
            print("Too many 404 errors when marking messages as read. Disabling this feature temporarily.");
          }
        }
      }
    } catch (e) {
      print("Error marking messages as read: $e");
    }
  }

  Future<void> sendMessage(String content) async {
    if (content.trim().isEmpty || _conversation == null) return;

    _controller.clear();
    
    // Clear typing status
    _setTyping(false);

    try {
      // Check if we have current user ID, if not try to get it
      if (_currentUserId == null || _currentUserId!.isEmpty) {
        print("No current user ID found when sending message, trying to retrieve it");
        await _getCurrentUserId();
        
        if (_currentUserId == null || _currentUserId!.isEmpty) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text('Unable to send message: User ID not found'))
          );
          return;
        }
      }

      // Get auth token
      final token = await storage.read(key: 'auth_token');
      if (token == null || token.isEmpty) {
        print("No auth token found when sending message");
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Unable to send message: Not authenticated'))
        );
        return;
      }
      
      // Get proper user name (if available)
      String userName = "You";
      String userAvatar = 'assets/images/avatar.png';
      
      final userJson = await storage.read(key: 'user');
      if (userJson != null) {
        try {
          final userData = json.decode(userJson);
          if (userData['name'] != null) {
            userName = userData['name'];
          }
          if (userData['avatar'] != null) {
            userAvatar = userData['avatar'];
          }
        } catch (e) {
          print("Error parsing user data: $e");
        }
      }

      // Generate a temporary ID for optimistic UI update
      final tempId = "${DateTime.now().millisecondsSinceEpoch}_temp";
      
      // Check if we've already sent a similar message in the last 5 seconds
      final recentSimilarMessages = _messages.where((msg) => 
        msg.senderId == _currentUserId &&
        msg.content == content &&
        DateTime.now().difference(msg.createdAt).inSeconds < 5
      ).toList();
      
      if (recentSimilarMessages.isNotEmpty) {
        print("Prevented duplicate send of message: $content");
        return;  // Skip sending duplicate message
      }
      
      // Optimistically add message to UI
      final tempMessage = Message(
        id: tempId,
        senderId: _currentUserId!,
        content: content,
        createdAt: DateTime.now(),
        conversationId: _conversation!.id,
        sender: User(
          id: _currentUserId!, 
          name: userName, 
          avatar: userAvatar, 
          role: 'user'
        ),
      );
      
      // Add message to UI
      setState(() {
        _messages.add(tempMessage);
        // Add to tracking set to prevent duplicates
        _messageIds.add(tempId);
        // Re-sort messages (not really needed for newly added message, but for consistency)
        _messages.sort((a, b) => a.createdAt.compareTo(b.createdAt));
      });
      
      // Scroll to the bottom after adding message
      _scrollToBottom();

      // Create a flag to track if message is confirmed
      bool messageConfirmed = false;

      // Send via HTTP to ensure it's stored in database
      try {
        print("Sending message via HTTP to store it");
        final response = await http.post(
          Uri.parse('${ApiConfig.baseUrl}/messages?userId=$_currentUserId'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
          body: json.encode({
            'content': content,
            'conversationId': _conversation!.id,
            'tempId': tempId,  // Include tempId to help with mapping
          }),
        );
        
        if (response.statusCode == 201) {
          print("Message successfully sent and stored via HTTP");
          messageConfirmed = true;
          
          // Demander au serveur d'envoyer une mise à jour des conversations
          // Cela va automatiquement mettre à jour l'écran des conversations
          socket?.emit('request_conversations_update', {
            'userId': _currentUserId
          });
          
          // Message successfully stored - update the temporary message with real data
          final messageData = json.decode(response.body);
          
          try {
            final realMessage = Message.fromJson(messageData);
            
            // Find and update the temporary message with the real one from the server
            setState(() {
              // Remove temp ID from tracking
              _messageIds.remove(tempId);
              
              // Find the temp message
              final index = _messages.indexWhere((msg) => msg.id == tempId);
              if (index >= 0) {
                // Replace with real message
                _messages[index] = realMessage;
                
                // Add real ID to tracking
                if (realMessage.id.isNotEmpty) {
                  _messageIds.add(realMessage.id);
                }
              }
            });
            
            // Update UI to show check mark immediately inside the message
            try {
              // Find the temporary message we're confirming
              final tempMessageIndex = _messages.indexWhere((msg) => msg.id == tempId);
              if (tempMessageIndex >= 0) {
                setState(() {
                  // Add a delivery confirmation status to the UI
                  HapticFeedback.lightImpact(); // Give a subtle vibration feedback
                });
              }
            } catch (e) {
              print("Error updating UI: $e");
            }
            
          } catch (parseError) {
            print("Error parsing real message data: $parseError");
          }
        } else {
          print("Failed to store message via HTTP: ${response.statusCode}");
          print("Response body: ${response.body}");
          
          // If HTTP storage fails, send via Socket as a fallback
          if (!messageConfirmed) {
            print("Sending message via socket as fallback for real-time delivery");
            socket?.emit('send_message', {
              'message': {
                'content': content,
                'conversationId': _conversation!.id,
                'sender': _currentUserId,
                'tempId': tempId,  // Include tempId to help with mapping
              }
            });
          }
        }
      } catch (e) {
        print("Error sending message via HTTP: $e");
      
        // If HTTP request fails, try socket as fallback
      if (!messageConfirmed) {
          print("Sending message via socket as fallback for real-time delivery");
        socket?.emit('send_message', {
          'message': {
            'content': content,
            'conversationId': _conversation!.id,
            'sender': _currentUserId,
              'tempId': tempId,  // Include tempId to help with mapping
          }
        });
        }
      }
    } catch (e) {
      print("Error sending message: $e");
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Failed to send message: ${e.toString().substring(0, math.min(e.toString().length, 50))}...'))
      );
    }
  }

  // Method to scroll to the bottom of the messages list
  void _scrollToBottom() {
    try {
      if (_scrollController.hasClients) {
        _scrollController.animateTo(
          _scrollController.position.maxScrollExtent,
          duration: Duration(milliseconds: 200),
          curve: Curves.easeOut,
        );
      }
    } catch (e) {
      print("Error scrolling to bottom: $e");
    }
  }

  void _setTyping(bool isTyping) {
    if (_currentUserId != null && _conversation != null) {
      socket?.emit('typing', {
        'conversationId': _conversation!.id,
        'isTyping': isTyping,
        'userId': _currentUserId
      });
    }
  }

  String _getConversationParticipantName() {
    if (_conversation == null || _conversation!.participantUsers == null || _conversation!.participantUsers!.isEmpty) {
      return widget.doctorName;
    }
    
    final user = _conversation!.participantUsers!.first;
    return user.name;
  }

  String _getConversationParticipantAvatar() {
    if (_conversation == null || _conversation!.participantUsers == null || _conversation!.participantUsers!.isEmpty) {
      return widget.doctorAvatar;
    }
    
    final user = _conversation!.participantUsers!.first;
    return user.avatar;
  }

  String _getCurrentTime() {
    final now = DateTime.now();
    final hour = now.hour > 12 ? now.hour - 12 : now.hour;
    final minute = now.minute.toString().padLeft(2, '0');
    final period = now.hour >= 12 ? 'PM' : 'AM';
    return '$hour:$minute $period';
  }

  void _highlightNewMessage(Message message) {
    // Method intentionally left empty - no highlighting needed
  }

  // Simplify notification banner method
  void showNotificationBanner(Message message) {
    if (!mounted) return;

    // Only show banner if user is not at the bottom of the chat
    bool isAtBottom = false;
    if (_scrollController.hasClients) {
      isAtBottom = _scrollController.position.pixels == _scrollController.position.maxScrollExtent;
    }

    if (!isAtBottom) {
      setState(() {
        _showNotificationBanner = true;
        _notificationMessage = message;
      });

      // Hide notification after 3 seconds
      Future.delayed(Duration(seconds: 3), () {
        if (mounted) {
          setState(() {
            _showNotificationBanner = false;
            _notificationMessage = null;
          });
        }
      });
    }
  }

  // Method to format timestamp for messages
  String _formatTimestamp(DateTime timestamp) {
    final now = DateTime.now();
    final today = DateTime(now.year, now.month, now.day);
    final yesterday = today.subtract(Duration(days: 1));
    final messageDate = DateTime(timestamp.year, timestamp.month, timestamp.day);
    
    if (messageDate == today) {
      // Today, show time only
      return '${timestamp.hour}:${timestamp.minute.toString().padLeft(2, '0')}';
    } else if (messageDate == yesterday) {
      // Yesterday
      return 'Yesterday';
    } else if (now.difference(timestamp).inDays < 7) {
      // Within a week, show day name
      final List<String> weekdays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
      return weekdays[timestamp.weekday - 1];
    } else {
      // Older messages, show date
      return '${timestamp.day}/${timestamp.month}';
    }
  }

  // Keep the original methods for getting user info by ID
  String _getParticipantName(String? senderId) {
    if (senderId == null) return widget.doctorName;
    
    final user = _users.firstWhere((u) => u.id == senderId, orElse: () => User(id: '', name: 'Unknown', avatar: 'assets/images/avatar.png', role: 'user'));
    return user.name;
  }

  String _getParticipantAvatar(String? senderId) {
    if (senderId == null) return widget.doctorAvatar;
    
    final user = _users.firstWhere((u) => u.id == senderId, orElse: () => User(id: '', name: 'Unknown', avatar: 'assets/images/avatar.png', role: 'user'));
    return user.avatar;
  }
  
  // Add new methods specifically for getting the other participant in the conversation
  String _getOtherParticipantName() {
    // If we don't have a conversation yet, use the provided doctor name
    if (_conversation == null) return widget.doctorName;
    
    // For group conversations, use the group name
    if (_conversation!.isGroup && _conversation!.groupName != null) {
      return _conversation!.groupName!;
    }
    
    // For direct conversations, find the other user
    if (_conversation!.participantUsers != null && _conversation!.participantUsers!.isNotEmpty) {
      // Find the other user (not the current user)
      final otherUser = _conversation!.participantUsers!.firstWhere(
        (user) => user.id != _currentUserId,
        orElse: () => User(id: '', name: widget.doctorName, avatar: widget.doctorAvatar, role: 'user')
      );
      return otherUser.name;
    }
    
    // If the conversation doesn't have participant details, try to find from users list
    if (_users.isNotEmpty && _conversation!.participants.isNotEmpty) {
      for (final participantId in _conversation!.participants) {
        if (participantId != _currentUserId) {
          final user = _users.firstWhere(
            (u) => u.id == participantId,
            orElse: () => User(id: '', name: widget.doctorName, avatar: widget.doctorAvatar, role: 'user')
          );
          if (user.id.isNotEmpty) {
            return user.name;
          }
        }
      }
    }
    
    // Default fallback
    return widget.doctorName;
  }

  String _getOtherParticipantAvatar() {
    // If we don't have a conversation yet, use the provided doctor avatar
    if (_conversation == null) return widget.doctorAvatar;
    
    // For group conversations, use a group avatar
    if (_conversation!.isGroup) {
      return 'assets/images/group.png';
    }
    
    // For direct conversations, find the other user
    if (_conversation!.participantUsers != null && _conversation!.participantUsers!.isNotEmpty) {
      // Find the other user (not the current user)
      final otherUser = _conversation!.participantUsers!.firstWhere(
        (user) => user.id != _currentUserId,
        orElse: () => User(id: '', name: widget.doctorName, avatar: widget.doctorAvatar, role: 'user')
      );
      return otherUser.avatar;
    }
    
    // If the conversation doesn't have participant details, try to find from users list
    if (_users.isNotEmpty && _conversation!.participants.isNotEmpty) {
      for (final participantId in _conversation!.participants) {
        if (participantId != _currentUserId) {
          final user = _users.firstWhere(
            (u) => u.id == participantId,
            orElse: () => User(id: '', name: widget.doctorName, avatar: widget.doctorAvatar, role: 'user')
          );
          if (user.id.isNotEmpty) {
            return user.avatar;
          }
        }
      }
    }
    
    // Default fallback
    return widget.doctorAvatar;
  }

  @override
  Widget build(BuildContext context) {
    // Fix _socket references throughout the file by making a minor change to the build method
    // This will force a rebuild and ensure all changes are picked up
    
    // Add a safety check to reset loading state if it's been too long
    if (_isLoadingChat) {
      Future.delayed(Duration(seconds: 5), () {
        if (mounted && _isLoadingChat) {
          print("Safety check in build: Resetting loading state that might be stuck");
          setState(() {
            _isLoadingChat = false;
          });
        }
      });
    }
    
    return Scaffold(
      backgroundColor: Colors.white,
      appBar: AppBar(
        backgroundColor: Colors.green,
        elevation: 0,
        leading: IconButton(
          icon: Icon(Icons.arrow_back, color: Colors.white),
          onPressed: () {
            Navigator.pop(context);
          },
        ),
        title: Row(
          children: [
            CircleAvatar(
              backgroundImage: AssetImage(widget.doctorAvatar),
              radius: 20,
            ),
            SizedBox(width: 10),
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    widget.doctorName,
                    style: TextStyle(fontSize: 16, color: Colors.white),
                    overflow: TextOverflow.ellipsis,
