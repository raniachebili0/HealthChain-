                                'Connecting...',
                                style: TextStyle(
                                  color: Colors.green.shade300,
                                  fontSize: 12,
                                ),
                              ),
                            ],
                          ),
                        )
                        : GestureDetector(
                            // Detect when user interacts with the message list
                            onTap: () {
                              if (_conversation != null) {
                                // Mark messages as read when user taps the list
                                markMessagesAsRead(_conversation!.id);
                              }
                            },
                            child: ListView.builder(
                              padding: EdgeInsets.symmetric(horizontal: 10),
                              controller: _scrollController,
                              itemCount: _messages.length,
                              itemBuilder: (context, index) {
                                print("Rendering message at index $index: ID=${_messages[index].id}, Content=${_messages[index].content}");
                                
                                final message = _messages[index];
                                final bool isCurrentUser = message.senderId == _currentUserId;
                                final isTemporary = message.id.contains('_temp');
                                final senderName = isCurrentUser ? "You" : (message.sender?.name ?? "Other user");
                                final messageContent = message.content.isNotEmpty ? message.content : "(No content)";
                                
                                return Container(
                                  padding: EdgeInsets.only(
                                    left: 14, 
                                    right: 14, 
                                    top: 10, 
                                    bottom: 10
                                  ),
                                  child: Align(
                                    alignment: isCurrentUser ? Alignment.topRight : Alignment.topLeft,
                                    child: InkWell(
                                      onTap: () {
                                        // If this is an unread message, mark all as read on tap
